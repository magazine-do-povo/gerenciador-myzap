{
  "name": "gerenciador-myzap",
  "description": "Gerenciador MyZap — disparo automático de mensagens via WhatsApp",
  "version": "1.4.3",
  "main": "main.js",
  "author": {
    "name": "JZ-TECH-SYS",
    "email": "contato@jztechsys.com"
  },
  "packageManager": "pnpm@10.29.3",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "nodemon --exec electron .",
    "build:icons": "powershell -ExecutionPolicy Bypass -File scripts/generate-windows-icon.ps1",
    "prepack": "pnpm run build:icons",
    "pack": "electron-builder --dir",
    "prebuild": "pnpm run build:icons",
    "build": "electron-builder",
    "predist": "pnpm run build:icons",
    "dist": "electron-builder",
    "predist:win32": "pnpm run build:icons",
    "dist:win32": "electron-builder --win --ia32 --config.directories.output=dist/win32",
    "predist:win64": "pnpm run build:icons",
    "dist:win64": "electron-builder --win --x64 --config.directories.output=dist/win64",
    "dist:linux": "electron-builder --linux AppImage deb",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-store": "^4.0.0",
    "extract-zip": "^2.0.1",
    "electron-updater": "^6.6.2",
    "pnpm": "10.29.3",
    "fix-path": "^2.1.0"
  },
  "devDependencies": {
    "electron": "*",
    "electron-builder": "^24.11.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "nodemon": "^3.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  },
  "build": {
    "appId": "com.jvtech.myzap",
    "productName": "gerenciador-myzap",
    "asarUnpack": [
      "node_modules/pnpm/**"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico",
      "artifactName": "gerenciador-myzap-Setup-${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "artifactName": "gerenciador-myzap-${version}.${ext}",
      "category": "Utility",
      "maintainer": "JZ-TECH-SYS <contato@jztechsys.com>"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Gerenciador MyZap",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "magazine-do-povo",
        "repo": "gerenciador-myzap"
      }
    ]
  }
}
